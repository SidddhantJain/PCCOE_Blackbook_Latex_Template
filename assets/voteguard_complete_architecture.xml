<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">

  <!-- Key definitions for nodes -->
  <key id="layer" for="node" attr.name="layer" attr.type="string"/>
  <key id="description" for="node" attr.name="description" attr.type="string"/>
  <key id="component_type" for="node" attr.name="component_type" attr.type="string"/>
  
  <!-- Key definitions for edges -->
  <key id="edge_type" for="edge" attr.name="edge_type" attr.type="string"/>
  <key id="edge_desc" for="edge" attr.name="edge_desc" attr.type="string"/>

  <graph id="VoteGuardArchitecture" edgedefault="directed">

    <!-- ===== PRESENTATION LAYER (UI/External Entrypoints) ===== -->
    <node id="n_voter_ui">
      <data key="layer">Presentation</data>
      <data key="component_type">UI</data>
      <data key="description">Voter Tablet/Kiosk Interface - Touch-based voting interface for voters</data>
    </node>

    <node id="n_eo_dashboard">
      <data key="layer">Presentation</data>
      <data key="component_type">UI</data>
      <data key="description">Election Officer Dashboard - Station management and voter enrollment</data>
    </node>

    <node id="n_auditor_console">
      <data key="layer">Presentation</data>
      <data key="component_type">UI</data>
      <data key="description">System Auditor Console - Audit trail and verification interface</data>
    </node>

    <node id="n_rest_api">
      <data key="layer">Presentation</data>
      <data key="component_type">Gateway</data>
      <data key="description">REST API Gateway - External service integration point</data>
    </node>

    <!-- ===== APPLICATION LAYER (Orchestration/Business Logic) ===== -->
    <node id="n_session_mgr">
      <data key="layer">Application</data>
      <data key="component_type">Manager</data>
      <data key="description">Session Manager - Manages user sessions and state transitions</data>
    </node>

    <node id="n_vote_cast">
      <data key="layer">Application</data>
      <data key="component_type">Orchestrator</data>
      <data key="description">Vote Casting Orchestrator - Coordinates vote capture and encryption</data>
    </node>

    <node id="n_enroll">
      <data key="layer">Application</data>
      <data key="component_type">Validator</data>
      <data key="description">Enrollment Validator - Validates voter eligibility and biometrics</data>
    </node>

    <node id="n_verify">
      <data key="layer">Application</data>
      <data key="component_type">Engine</data>
      <data key="description">Verification Engine - Post-cast vote verification and confirmation</data>
    </node>

    <node id="n_tally">
      <data key="layer">Application</data>
      <data key="component_type">Calculator</data>
      <data key="description">Tally Calculator - Aggregates votes and produces results</data>
    </node>

    <!-- ===== DOMAIN LAYER (Business Entities & Rules) ===== -->
    <node id="n_voter_entity">
      <data key="layer">Domain</data>
      <data key="component_type">Entity</data>
      <data key="description">Voter Entity - Represents voter with biometric, enrollment status</data>
    </node>

    <node id="n_ballot_entity">
      <data key="layer">Domain</data>
      <data key="component_type">Entity</data>
      <data key="description">Ballot Entity - Represents encrypted vote with candidate selections</data>
    </node>

    <node id="n_cast_registry">
      <data key="layer">Domain</data>
      <data key="component_type">Service</data>
      <data key="description">Cast Registry - Tracks all cast votes with temporal ordering</data>
    </node>

    <node id="n_crypto">
      <data key="layer">Domain</data>
      <data key="component_type">Service</data>
      <data key="description">Cryptography Service - End-to-end encryption, signing, verification</data>
    </node>

    <node id="n_state_machine">
      <data key="layer">Domain</data>
      <data key="component_type">Service</data>
      <data key="description">State Machine - Enforces valid state transitions for votes</data>
    </node>

    <!-- ===== PORTS (Abstractions/Interfaces) ===== -->
    <node id="n_storage_port">
      <data key="layer">Ports</data>
      <data key="component_type">Interface</data>
      <data key="description">IStorage Port - Abstract persistent storage contract</data>
    </node>

    <node id="n_audit_port">
      <data key="layer">Ports</data>
      <data key="component_type">Interface</data>
      <data key="description">IAudit Port - Abstract audit logging contract</data>
    </node>

    <node id="n_chain_port">
      <data key="layer">Ports</data>
      <data key="component_type">Interface</data>
      <data key="description">IChainAnchor Port - Abstract blockchain anchoring contract</data>
    </node>

    <node id="n_device_port">
      <data key="layer">Ports</data>
      <data key="component_type">Interface</data>
      <data key="description">IDevice Port - Abstract hardware device interaction</data>
    </node>

    <!-- ===== ADAPTERS (Implementation Bridges) ===== -->
    <node id="n_storage_adapter">
      <data key="layer">Adapters</data>
      <data key="component_type">Adapter</data>
      <data key="description">StorageHashChainAdapter - Maps votes to hash chain for tamper detection</data>
    </node>

    <node id="n_audit_adapter">
      <data key="layer">Adapters</data>
      <data key="component_type">Adapter</data>
      <data key="description">AuditLogHashChainAdapter - Chains audit logs for integrity verification</data>
    </node>

    <node id="n_chain_adapter">
      <data key="layer">Adapters</data>
      <data key="component_type">Adapter</data>
      <data key="description">ChainAnchorServiceAdapter - Anchors vote commitments to blockchain</data>
    </node>

    <node id="n_device_adapter">
      <data key="layer">Adapters</data>
      <data key="component_type">Adapter</data>
      <data key="description">DeviceMockAdapter - Interfaces biometric scanners and card readers</data>
    </node>

    <!-- ===== INFRASTRUCTURE (External Systems & Resources) ===== -->
    <node id="n_file_store">
      <data key="layer">Infrastructure</data>
      <data key="component_type">Storage</data>
      <data key="description">Encrypted File Store - Persistent AES-256 encrypted vote storage</data>
    </node>

    <node id="n_audit_store">
      <data key="layer">Infrastructure</data>
      <data key="component_type">Storage</data>
      <data key="description">Audit Store - Append-only audit trail with hash chain</data>
    </node>

    <node id="n_bio_scanner">
      <data key="layer">Infrastructure</data>
      <data key="component_type">Device</data>
      <data key="description">Biometric Scanner - Fingerprint/iris capture for voter authentication</data>
    </node>

    <node id="n_card_reader">
      <data key="layer">Infrastructure</data>
      <data key="component_type">Device</data>
      <data key="description">Card Reader - Voter ID verification via smartcard/RFID</data>
    </node>

    <node id="n_printer">
      <data key="layer">Infrastructure</data>
      <data key="component_type">Device</data>
      <data key="description">Receipt Printer - Voter-verified paper audit trail (VVPAT)</data>
    </node>

    <node id="n_blockchain">
      <data key="layer">Infrastructure</data>
      <data key="component_type">Service</data>
      <data key="description">Blockchain Service - Immutable vote commitment anchoring</data>
    </node>

    <node id="n_remote_verif">
      <data key="layer">Infrastructure</data>
      <data key="component_type">Service</data>
      <data key="description">Remote Verification - External vote integrity verification API</data>
    </node>

    <!-- ===== EDGES / RELATIONSHIPS ===== -->
    
    <!-- Presentation → Application flows -->
    <edge id="e1" source="n_voter_ui" target="n_vote_cast">
      <data key="edge_type">invoke</data>
      <data key="edge_desc">Voter submits vote via UI</data>
    </edge>

    <edge id="e2" source="n_voter_ui" target="n_session_mgr">
      <data key="edge_type">invoke</data>
      <data key="edge_desc">Voter session management</data>
    </edge>

    <edge id="e3" source="n_eo_dashboard" target="n_enroll">
      <data key="edge_type">invoke</data>
      <data key="edge_desc">Election officer enrolls voters</data>
    </edge>

    <edge id="e4" source="n_auditor_console" target="n_verify">
      <data key="edge_type">invoke</data>
      <data key="edge_desc">Auditor requests vote verification</data>
    </edge>

    <edge id="e5" source="n_rest_api" target="n_tally">
      <data key="edge_type">invoke</data>
      <data key="edge_desc">External services query results</data>
    </edge>

    <!-- Application → Domain flows -->
    <edge id="e6" source="n_vote_cast" target="n_ballot_entity">
      <data key="edge_type">creates</data>
      <data key="edge_desc">Vote cast creates ballot record</data>
    </edge>

    <edge id="e7" source="n_vote_cast" target="n_crypto">
      <data key="edge_type">uses</data>
      <data key="edge_desc">Encrypts vote with public key</data>
    </edge>

    <edge id="e8" source="n_vote_cast" target="n_state_machine">
      <data key="edge_type">uses</data>
      <data key="edge_desc">Validates vote state transitions</data>
    </edge>

    <edge id="e9" source="n_enroll" target="n_voter_entity">
      <data key="edge_type">creates</data>
      <data key="edge_desc">Creates voter record with biometric</data>
    </edge>

    <edge id="e10" source="n_verify" target="n_cast_registry">
      <data key="edge_type">queries</data>
      <data key="edge_desc">Retrieves cast vote history</data>
    </edge>

    <edge id="e11" source="n_tally" target="n_cast_registry">
      <data key="edge_type">reads</data>
      <data key="edge_desc">Aggregates all cast votes</data>
    </edge>

    <edge id="e12" source="n_tally" target="n_crypto">
      <data key="edge_type">uses</data>
      <data key="edge_desc">Decrypts votes for tallying</data>
    </edge>

    <!-- Domain → Ports flows -->
    <edge id="e13" source="n_ballot_entity" target="n_storage_port">
      <data key="edge_type">uses_port</data>
      <data key="edge_desc">Persists encrypted ballot</data>
    </edge>

    <edge id="e14" source="n_cast_registry" target="n_audit_port">
      <data key="edge_type">uses_port</data>
      <data key="edge_desc">Logs cast registry operations</data>
    </edge>

    <edge id="e15" source="n_crypto" target="n_chain_port">
      <data key="edge_type">uses_port</data>
      <data key="edge_desc">Anchors vote commitment</data>
    </edge>

    <edge id="e16" source="n_enroll" target="n_device_port">
      <data key="edge_type">uses_port</data>
      <data key="edge_desc">Captures biometric data</data>
    </edge>

    <!-- Ports → Adapters flows -->
    <edge id="e17" source="n_storage_port" target="n_storage_adapter">
      <data key="edge_type">implements</data>
      <data key="edge_desc">Storage port implementation</data>
    </edge>

    <edge id="e18" source="n_audit_port" target="n_audit_adapter">
      <data key="edge_type">implements</data>
      <data key="edge_desc">Audit logging implementation</data>
    </edge>

    <edge id="e19" source="n_chain_port" target="n_chain_adapter">
      <data key="edge_type">implements</data>
      <data key="edge_desc">Blockchain anchor implementation</data>
    </edge>

    <edge id="e20" source="n_device_port" target="n_device_adapter">
      <data key="edge_type">implements</data>
      <data key="edge_desc">Device I/O implementation</data>
    </edge>

    <!-- Adapters → Infrastructure flows -->
    <edge id="e21" source="n_storage_adapter" target="n_file_store">
      <data key="edge_type">writes</data>
      <data key="edge_desc">Stores encrypted votes</data>
    </edge>

    <edge id="e22" source="n_audit_adapter" target="n_audit_store">
      <data key="edge_type">appends</data>
      <data key="edge_desc">Appends to audit trail</data>
    </edge>

    <edge id="e23" source="n_chain_adapter" target="n_blockchain">
      <data key="edge_type">publishes</data>
      <data key="edge_desc">Publishes commitment to blockchain</data>
    </edge>

    <edge id="e24" source="n_device_adapter" target="n_bio_scanner">
      <data key="edge_type">io</data>
      <data key="edge_desc">Biometric I/O communication</data>
    </edge>

    <edge id="e25" source="n_device_adapter" target="n_card_reader">
      <data key="edge_type">io</data>
      <data key="edge_desc">Card reader I/O communication</data>
    </edge>

    <edge id="e26" source="n_vote_cast" target="n_printer">
      <data key="edge_type">io</data>
      <data key="edge_desc">Prints voter receipt</data>
    </edge>

    <!-- Remote verification flows -->
    <edge id="e27" source="n_verify" target="n_remote_verif">
      <data key="edge_type">calls</data>
      <data key="edge_desc">External vote verification</data>
    </edge>

    <edge id="e28" source="n_remote_verif" target="n_blockchain">
      <data key="edge_type">queries</data>
      <data key="edge_desc">Queries commitment on blockchain</data>
    </edge>

  </graph>
</graphml>